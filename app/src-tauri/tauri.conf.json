{
  "productName": "AIPet",
  "version": "0.4.0",
  "identifier": "com.wonderland6627.aipet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AIPet",
        "width": 192,
        "height": 208,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      },
      {
        "label": "settings",
        "title": "AIPet Settings",
        "width": 1000,
        "height": 700,
        "minWidth": 900,
        "minHeight": 650,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundled-pets/**/*": "bundled-pets/"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Wonderland6627/AIPet/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQKGhibydL8Lrq1pFuTd39AFTx+61gBEHbbnsjPN9UtWD1o+fHqs6Ie"
    }
  }
}
